{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://printgenius-ai-studio.onrender.com/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://printgenius-ai-studio.onrender.com/assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
