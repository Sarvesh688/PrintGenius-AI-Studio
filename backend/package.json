{
  "name": "printgenius-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for PrintGenius AI Studio - AI-powered print-on-demand platform",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && cp ./package.json ./dist",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mern",
    "ai",
    "print-on-demand",
    "nodejs",
    "express",
    "mongodb",
    "typescript",
    "stripe",
    "cloudinary"
  ],
  "author": "Sarvesh Kumar <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sarvesh688/PrintGenius-AI-Studio.git"
  },
  "homepage": "https://github.com/Sarvesh688/PrintGenius-AI-Studio#readme",
  "dependencies": {
    "ai": "^6.0.5",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "mongoose": "^8.23.0",
    "slugify": "^1.6.8",
    "stripe": "^20.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.19.15",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
